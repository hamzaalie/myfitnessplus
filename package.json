{
  "name": "myfitnessplus",
  "version": "1.0.0",
  "description": "MyFitnessPlus - A fitness tracking web application",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "nodemon server/server.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install",
    "seed:workouts": "node server/scripts/seedWorkouts.js",
    "seed:goals": "node server/scripts/seedGoals.js",
    "seed:meals": "node server/scripts/seedMeals.js",
    "seed:all": "node server/scripts/seedAll.js"
  },
  "keywords": ["fitness", "health", "workout", "meal-prep"],
  "author": "MyFitnessPlus Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
